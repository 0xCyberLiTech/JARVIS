# ════════════════════════════════════════════════════════════════
# .gitignore — JARVIS · 0xCyberLiTech
# Dépôt 100% LOCAL — aucun remote configuré.
# Ce fichier protège quand même les secrets au cas où un remote
# serait ajouté un jour.
# ════════════════════════════════════════════════════════════════

# ── SECRETS / CREDENTIALS — exclusion absolue ──────────────────
scripts/jarvis_secret.key
scripts/jarvis_pve.json
scripts/soc_config.json

# ── Gros binaires (modèles, voix, embeddings) ──────────────────
models/
scripts/voices/*.onnx
scripts/voices/*.onnx.json
scripts/jarvis_rag/embeddings.npy
scripts/jarvis_rag/meta.json
node_modules/

# ── Données runtime (changent en continu, pas du code) ─────────
scripts/jarvis_facts.json
scripts/jarvis_memory.json
scripts/jarvis_memory_summary.json
scripts/jarvis_soc_actions.json
scripts/jarvis_soc_autobanned.json
scripts/jarvis_soc_cooldowns.json
# tâches utilisateur de la tuile tasks/ (créées/éditées via UI Tâches)
scripts/jarvis_tasks.json
# réglages EQ/DSP réécrits à chaque clic UI · défauts dans jarvis.py:87
scripts/jarvis_dsp_params.json
# params LLM (num_ctx adaptatif) réécrits au runtime · défauts dans le code
scripts/jarvis_llm_params.json
# prompt système réécrit par _applyModeProfile à chaque switch de mode
# (état runtime volatil — régénéré au boot via _applyModeProfile('soc'))
scripts/jarvis_system_prompt.txt
scripts/voice_prints/
scripts/generated_code/
*.log
*.log.*
# Logs structures JSONL (audit write ops SSH, ajoute 2026-05-17)
logs/
*.jsonl

# ── Artefacts / caches ─────────────────────────────────────────
__pycache__/
*.pyc
.ruff_cache/
.pytest_cache/
.coverage
coverage.json
htmlcov/
test-results/
playwright-report/

# ── Snapshots locaux du chantier dette (Copy-Item) ─────────────
scripts.snapshot-*/
scripts.action*/
scripts.matin-*/
scripts.aprem-*/
*.bak
*.bak[0-9]
*.bak.*
